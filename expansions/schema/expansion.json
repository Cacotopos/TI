{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Expansion Site Config",
  "type": "object",
  "required": ["id", "name", "version"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "release_date": { "type": "string" },
    "source": {
      "type": "object",
      "properties": {
        "images": { "type": "string" },
        "icons": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "type"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "type": { "type": "string", "enum": ["markdown", "cards", "list"] },
          "content": { "type": "string" },
          "items": { "type": "array" }
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "component": { "type": "string", "enum": ["us-mini", "tarot", "poker", "tile", "player-sheet", "token", "other"] },
          "tileType": { "type": "string", "enum": ["home-system", "nexus", "hyperlane", "anomaly"] },
          "anomalies": { "type": "array", "items": { "type": "string", "enum": ["Asteroid", "Scar", "Gravity Rift", "Fracture", "Empty", "Nebula"] } },
          "isCard": { "type": "boolean" }
        }
      }
    }
  }
}
